---
import ArchiveLabel from './ArchiveLabel.astro'; const {art,prev,next,index}=Astro.props;
---
<article class="detail"><div class="detail-image"><img src={art.image} alt={art.alt}/><span class="vertical">JUNGDESIGN / WORK {String(index+1).padStart(2,'0')}</span></div><div class="detail-copy"><ArchiveLabel index={String(index+1).padStart(2,'0')}>{art.group}</ArchiveLabel><h1>{art.title}</h1><p class="studio-note">{art.note}</p><dl><div><dt>Year</dt><dd>{art.year}</dd></div><div><dt>Medium</dt><dd>{art.medium}</dd></div><div><dt>Size</dt><dd>{art.dimensions}</dd></div><div><dt>Status</dt><dd>{art.availability}</dd></div></dl><div class="detail-actions"><a class="button" href={`/contact?artwork=${art.slug}`}>Enquire about this work</a><a class="button light" href="/paintings/catalog/">Catalog A–Z</a></div></div></article><nav class="work-nav"><a href={`/paintings/${prev.slug}/`}>← Previous<br/><b>{prev.title}</b></a><a href="/paintings">All works</a><a href="/paintings/catalog/">Catalog A–Z</a><a href={`/paintings/${next.slug}/`}>Next →<br/><b>{next.title}</b></a></nav>
