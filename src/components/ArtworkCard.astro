---
const {art,index=0,priority=false}=Astro.props;
const rhythm=['major','minor','third','third','third','minor','major','third','third','third','major','minor'];
const specialSizes={
  'buzzy-bee':'full',
  'falcon':'major',
  'self-ii':'minor',
  'mother':'full',
  'boat':'full',
  'blam-blam':'minor',
  'with-tony':'major',
  'barlow':'full',
  'kids-on-court':'full',
  'tony-king':'minor'
};
const size=specialSizes[art.slug]??(art.slug==='view'?'third':rhythm[index%rhythm.length]);
const preserveFull=['buzzy-bee','falcon','self-ii','blam-blam','with-tony','barlow','kids-on-court','tony-king'].includes(art.slug);
---
<article class:list={['art-card',`work-${art.slug}`,`size-${size}`,art.slug==='lady'&&'show-whole',art.slug==='mother'&&'show-wide',preserveFull&&'preserve-full']}><a href={`/paintings/${art.slug}/`}><div class="art-image"><img src={art.image} alt={art.alt} loading={priority?'eager':'lazy'} decoding="async"/></div><div class="art-caption"><span>{String(index+1).padStart(2,'0')} / {art.group}</span><h2>{art.title}</h2><i>View work ↗</i></div></a></article>
