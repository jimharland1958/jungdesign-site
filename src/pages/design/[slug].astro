---
import Layout from '../../components/Layout.astro';
import projects from '../../data/projects.json';

export function getStaticPaths(){
  return projects.map((project)=>({params:{slug:project.slug},props:{project}}));
}

const {project}=Astro.props;
const next = projects[(projects.findIndex((item)=>item.slug===project.slug)+1)%projects.length];
const previous = projects[(projects.findIndex((item)=>item.slug===project.slug)-1+projects.length)%projects.length];
---
<Layout title={`${project.title} — Development — JungDesign`} description={project.summary}>
  <main class="project-page editorial-project">
    <section class="project-hero">
      <div class="project-hero-copy">
        <span class="eyebrow">{project.type} / {project.period}</span>
        <h1>{project.title}</h1>
        <p class="lede">{project.summary}</p>
        <div class="case-thesis">
          <b>Proof point</b>
          <p>{project.note}</p>
        </div>
      </div>
      <div class="project-hero-image project-hero-card">
        <span class="vertical">JUNGDESIGN / CASE {project.number}</span>
        <figure class="project-source-image large"><img src={project.image} alt={project.imageAlt} loading="eager" decoding="async"/><figcaption>{project.visual.label}</figcaption></figure>
        <p>{project.role}</p>
      </div>
    </section>

    <section class="project-facts">
      <dl>
        <div><dt>Client / context</dt><dd>{project.client}</dd></div>
        <div><dt>David’s role</dt><dd>{project.role}</dd></div>
        <div><dt>Disciplines</dt><dd>{project.disciplines.join(' / ')}</dd></div>
      </dl>
    </section>

    <section class="case-story">
      <article>
        <b>01</b>
        <h2>What had to be solved</h2>
        <p>{project.problem}</p>
      </article>
      <article>
        <b>02</b>
        <h2>What JungDesign did</h2>
        <p>{project.response}</p>
      </article>
      <article>
        <b>03</b>
        <h2>Why it mattered</h2>
        <p>{project.outcome}</p>
      </article>
    </section>

    <section class="project-note">
      <b>Connection to the paintings</b>
      <p>This kind of work explains the structure in David’s paintings: the clear edge, the controlled crop, the object treated seriously, and the confidence that comes from decades of making ideas survive contact with real-world constraints.</p>
    </section>

    <nav class="work-nav" aria-label="Development project navigation">
      <a href={`/design/${previous.slug}/`}>← {previous.title}</a>
      <a href="/design/">Development index</a>
      <a href={`/design/${next.slug}/`}>{next.title} →</a>
    </nav>
  </main>
</Layout>
