---
import Layout from '../../components/Layout.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import projects from '../../data/projects.json';

const productWork = projects.slice(5);
const productPreview = productWork.filter((project)=>[
  'vps-vine-pod-system',
  'five-litre-measuring-jug',
  'hospital-labelling-system',
  'ericsson-phone-system-casing',
  'egg-splitter-system',
  'eyeque-airport-security-system'
].includes(project.slug));
const productPillars = [
  ['Useful', 'Objects and systems are judged by what they let people do more clearly, safely or efficiently.'],
  ['Buildable', 'A JungDesign idea has to survive manufacture, installation, cost, handling and repeated use.'],
  ['Observed', 'The work begins with close attention to friction: where hands go, what goes wrong, what needs to be legible.'],
  ['Still active', 'VPS continues the same line of thinking: a practical mechanism for a specific environmental problem.']
];
---
<Layout title="Product Development — JungDesign" description="David Jung’s JungDesign product-development work: useful objects, safer systems, better mechanisms and practical product thinking.">
  <SectionIntro eyebrow="Product Development / Systems & objects" title="Useful things, safer systems, better mechanisms." intro="This page gathers David Jung’s product-development work: industrial objects, casings, airport and medical systems, food-safety mechanisms and current environmental product thinking."/>

  <section class="dev-manifesto">
    <div class="dev-manifesto-mark">PD</div>
    <div>
      <span class="eyebrow">Product-development spine</span>
      <p>Product development is where JungDesign turns observation into practical form: the clearer pour, the safer label, the better casing, the more reliable airport process, the mechanism that reduces waste, risk or confusion.</p>
      <p>These are not decorative projects. They are working propositions — designed to be made, installed, tested, used, revised and understood.</p>
    </div>
  </section>

  <section class="career-pillars" aria-label="JungDesign product-development principles">
    {productPillars.map(([title,copy],index)=><article>
      <b>{String(index+1).padStart(2,'0')}</b>
      <h2>{title}</h2>
      <p>{copy}</p>
    </article>)}
  </section>

  <section class="project-index product-index">
    <div class="project-index-intro">
      <span class="eyebrow">Product development</span>
      <h2>Useful things, safer systems, better mechanisms.</h2>
      <p>Across product and system work, the pattern is consistent: define the friction, make the use clearer, and develop a response that can be manufactured, installed, trialled or operated.</p>
      <a class="montage-preview-card" href="/design/montage/" aria-label="View Product Development image montage">
        <span class="eyebrow">Product image montage</span>
        <div class="montage-preview-grid" aria-hidden="true">
          {productPreview.map((project)=><img src={project.slug==='vps-vine-pod-system'?'/images/project-sources/vine-pod-overlay.jpg':project.image} alt="" loading="lazy" decoding="async"/>) }
        </div>
        <strong>View the visual wall →</strong>
      </a>
    </div>
    <div class="project-index-grid compact">
      {productWork.map((project)=><a class="project-tile text-only" href={`/design/${project.slug}/`}>
        <figure class:list={["project-source-image", `project-${project.slug}`]}><img src={project.image} alt={project.imageAlt} loading="lazy" decoding="async"/><figcaption>{project.visual.label}</figcaption></figure>
        <span>{project.number} / {project.period}</span>
        <h3>{project.title}</h3>
        <p>{project.summary}</p>
        <dl class="proof-points">
          <div><dt>Problem</dt><dd>{project.problem}</dd></div>
          <div><dt>Response</dt><dd>{project.response}</dd></div>
        </dl>
        <small class="project-outcome">Outcome: {project.outcome}</small>
        <i>Open project →</i>
      </a>)}
    </div>
  </section>

  <section class="career-spine">
    <span class="eyebrow">How to read this work</span>
    <h2>Product development here means practical imagination.</h2>
    <p>The common thread is not a style. It is a way of thinking: notice the awkward part of a real-world process, then design the object, label, casing, interface or mechanism that makes it less awkward.</p>
    <p>That same exactness sits behind the paintings: object intelligence, strong edges, legibility, humour and a designer’s respect for how things are put together.</p>
  </section>

  <ContactCTA title="A product-development conversation?" copy="David welcomes selected product, system and project enquiries alongside questions about the paintings."/>
</Layout>
