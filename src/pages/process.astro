---
import Layout from '../components/Layout.astro'; import SectionIntro from '../components/SectionIntro.astro'; import ContactCTA from '../components/ContactCTA.astro';
const notes=[['LOOKING / 01','/images/artworks/BlueTrike1.jpg','Start with the object','A tricycle is also a machine, a memory and a choreography of circles. Careful looking supplies the composition.'],['CROPPING / 02','/images/artworks/Superman1.jpg','Choose the charged edge','The frame can withhold as much as it reveals. A close crop gives familiar material a new pressure.'],['DRAWING / 03','/images/artworks/House1.jpg','Structure before spectacle','Line establishes proportion, rhythm and trust. Detail arrives through patience, not decoration.'],['COLOUR / 04','/images/artworks/OMG1.jpg','Let colour do the talking','Red, yellow and deep blue behave like voices: each has a volume, a pace and a role.']];
---
<Layout title="Process & Studio Notes — Jungdesign"><SectionIntro eyebrow="Studio drawer 03 / Work in progress" title="Notes from the studio" intro="A place for sketches, close-ups, working thoughts and the small decisions that accumulate into a painting. David’s own notes can replace these first-draft observations over time."/><section class="notes">{notes.map((n,i)=><article class:list={[i%2?'reverse':'']}><div class="note-img"><img src={n[1]} alt="Artwork detail" loading="lazy"/></div><div><b>{n[0]}</b><h2>{n[2]}</h2><p>{n[3]}</p><span class="scribble">studio note / replace me</span></div></article>)}</section><ContactCTA/></Layout>
