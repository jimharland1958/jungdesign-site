---
import Layout from '../../components/Layout.astro'; import SectionIntro from '../../components/SectionIntro.astro'; import ArtworkGrid from '../../components/ArtworkGrid.astro'; import ContactCTA from '../../components/ContactCTA.astro'; import artworks from '../../data/artworks.json';
---
<Layout title="Paintings — David Jung | JungDesign"><SectionIntro eyebrow={`The main exhibition / ${artworks.length} works`} title="Paintings" intro="Objects become characters. Memories sharpen into scenes. Comic panels pause mid-thought. Browse the whole wall, or follow one line of inquiry."/><div class="filter" aria-label="Artwork categories"><button class="active" data-group="all">All works</button>{[...new Set(artworks.map(a=>a.group))].map(g=><button data-group={g}>{g}</button>)}</div><div id="gallery"><ArtworkGrid artworks={artworks}/></div><section class="paintings-montage" aria-label="David Jung painting montage"><span class="eyebrow">Studio wall fragment</span><img src="/images/artworks/Montage.jpg" alt="Montage of David Jung works including Buzzy Bee, shoes, cricket figure and Snowy Quiet comic panel" loading="lazy" decoding="async"/></section><ContactCTA/></Layout>
<script>const bs=[...document.querySelectorAll('.filter button')], cs=[...document.querySelectorAll('.art-card')];bs.forEach(b=>b.addEventListener('click',()=>{bs.forEach(x=>x.classList.remove('active'));b.classList.add('active');const g=b.dataset.group;cs.forEach(c=>{const t=c.querySelector('.art-caption span')?.textContent||'';c.toggleAttribute('hidden',g!=='all'&&!t.includes(g||''))})}))</script>
