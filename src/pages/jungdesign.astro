---
import Layout from '../components/Layout.astro';
---
<Layout title="JungDesign — David Jung" description="JungDesign in motion: a film from six decades of creative practice.">
  <section class="jungdesign-film">
    <div class="film-type" aria-hidden="true"><span>04</span><b>JUNG<br/>DESIGN</b></div>
    <div class="film-frame">
      <blockquote class="instagram-media" data-instgrm-captioned data-instgrm-permalink="https://www.instagram.com/reel/DX0rglyChjM/?utm_source=ig_embed&amp;utm_campaign=loading" data-instgrm-version="14">
        <a class="film-placeholder" href="https://www.instagram.com/reel/DX0rglyChjM/" target="_blank" rel="noopener" aria-label="Open the JungDesign film on Instagram">
          <img src="/images/jungdesign-logo.png" alt=""/>
          <span aria-hidden="true">▶</span>
        </a>
      </blockquote>
    </div>
    <div class="film-label"><b>JUNGDESIGN / IN MOTION</b><span>Sixty years of looking, making and thinking.</span></div>
  </section>
  <script async src="https://www.instagram.com/embed.js" is:inline></script>
</Layout>
